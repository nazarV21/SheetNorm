# Flask
SECRET_KEY=replace-with-a-random-secret
FLASK_DEBUG=false

# Local pilot: SQLite. Team/Enterprise: PostgreSQL.
DATA_STORE_BACKEND=database
DATABASE_URL=sqlite:///sheetnorm.db
AUTO_CREATE_SQLITE_DB=true
AUTO_REPAIR_SQLITE_SCHEMA=true

# Local mode without Redis. Use rq for server deployment.
ASYNC_MODE=thread
LOCAL_WORKER_THREADS=1
RQ_DEFAULT_TIMEOUT=600
RQ_RESULT_TTL=86400
RQ_FAILURE_TTL=604800
REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=sheetnorm

# Files
MAX_UPLOAD_MB=50
STORAGE_BACKEND=local
STORAGE_ROOT=storage
SOURCE_FILE_RETENTION_DAYS=30
RESULT_FILE_RETENTION_DAYS=30
TEMP_FILE_RETENTION_HOURS=24

# Local AI
AI_BACKEND=llama_cpp
AI_MODELS_DIR=models
AI_MODEL_PATH=
AI_SETTINGS_FILE=ai_settings.json

# Automatic selection and logical activation. The GGUF loads lazily on first AI request.
AI_MODEL_SELECTION_MODE=auto
AI_AUTO_SELECT_ON_STARTUP=true
AI_AUTO_ACTIVATE=true
AI_AUTO_TEST=true
AI_RESELECT_IF_UNAVAILABLE=true
AI_MIN_FREE_RAM_GB=2
AI_MAX_RAM_USAGE_RATIO=0.72

# Runtime defaults
AI_DEFAULT_PROFILE=balanced
AI_CONTEXT_TOKENS=4096
AI_MAX_COMPLETION_TOKENS=1000
AI_MAX_TRAINING_EXAMPLES=8
AI_N_THREADS=4
AI_N_BATCH=128
AI_N_GPU_LAYERS=0
AI_TEMPERATURE=0.15
AI_ALLOW_FALLBACK=true
AI_MODEL_LOAD_TIMEOUT_SECONDS=180
AI_MODEL_TEST_TIMEOUT_SECONDS=240
AI_MEMORY_MODE=economy
AI_IDLE_UNLOAD_SECONDS=300
AI_USE_LEARNED_HINTS=false

# Pandas script execution
SCRIPT_EXECUTION_ENABLED=false
SCRIPT_TIMEOUT_SECONDS=30
SCRIPT_MAX_MEMORY_MB=512
SCRIPT_MAX_OUTPUT_ROWS=1000000
SCRIPT_MAX_OUTPUT_COLUMNS=500
SCRIPT_MAX_CODE_LENGTH=30000
SCRIPT_REPAIR_ATTEMPTS=1

CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5000
